---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import entries from '../../data/entries.json';
import topics from '../../data/topics.json';

export async function getStaticPaths() {
  return topics.map((topic) => ({
    params: { slug: topic.slug },
    props: { topic },
  }));
}

const { topic } = Astro.props;

const descPath = path.resolve('src/content/topics', topic.descriptionFile);
let descHtml = '';
if (fs.existsSync(descPath)) {
  descHtml = fs.readFileSync(descPath, 'utf-8');
}

const topicEntries = topic.entries
  .map((slug) => entries.find((e) => e.slug === slug))
  .filter((e): e is NonNullable<typeof e> => e != null);
---

<BaseLayout title={topic.title}>
  <h1>{topic.title}</h1>

  <div class="topic-description">
    <Fragment set:html={descHtml} />
  </div>

  <ol>
    {topicEntries.map((entry) => (
      <li>
        <a href={`/entry/${entry.slug}`}>{entry.title}</a>
        <time>{entry.date}</time>
      </li>
    ))}
  </ol>
</BaseLayout>
